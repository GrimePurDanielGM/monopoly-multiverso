# ============================================================================
# Variables del CLIENTE (navegador). Prefijo VITE_ => se incrustan en el bundle.
# AQUÍ SOLO PUEDEN IR VALORES PÚBLICOS. Nunca un secreto con prefijo VITE_.
# ============================================================================
VITE_SUPABASE_URL=            # URL pública del proyecto Supabase (ej. http://localhost:54321 en local)
VITE_SUPABASE_ANON_KEY=       # Clave anónima pública (segura porque RLS protege el estado)
VITE_PUBLIC_BASE_URL=         # Dominio canónico para enlaces/QR (def. https://monopoly-multiverso-web.vercel.app)

# ============================================================================
# Variables del SERVIDOR. NO llevan prefijo VITE_ y NUNCA llegan al navegador.
# En local: .env (gitignored). En producción: sistema de secretos de Supabase
#   (supabase secrets set ...). No deben aparecer en el bundle, logs ni repo.
# ============================================================================
SUPABASE_URL=                 # URL del proyecto (uso server/CLI)
SUPABASE_SERVICE_ROLE_KEY=    # SECRETO. Solo Edge Functions. Jamás en el cliente.
SUPABASE_DB_URL=              # SECRETO. Cadena de conexión para migraciones/CLI
HOST_PIN_PEPPER=              # SECRETO. "Pepper" para el hash del PIN de anfitrión (se usará en Fase 1)
