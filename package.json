{
  "name": "monopoly-multiverso",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @multiverso/web dev",
    "build": "pnpm --filter @multiverso/web build",
    "preview": "pnpm --filter @multiverso/web preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "pnpm -r --parallel typecheck",
    "test": "pnpm -r --parallel test:run",
    "test:engine": "pnpm --filter @multiverso/engine test:run",
    "e2e": "playwright test",
    "verify:engine": "node scripts/verify-shared-engine.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.2",
    "eslint": "^9.12.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.10.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "@eslint/js": "^9.12.0",
    "typescript-eslint": "^8.8.0"
  }
}
